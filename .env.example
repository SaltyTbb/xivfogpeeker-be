# FFLogs API (OAuth2 client credentials)
# Get these from: https://www.fflogs.com/api/clients/
FFLOGS_CLIENT_ID=your_fflogs_client_id_here
FFLOGS_CLIENT_SECRET=your_fflogs_client_secret_here

# DeepSeek API (OpenAI-compatible)
# Get this from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
